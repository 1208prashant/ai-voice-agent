# Gemini API (required)
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-1.5-flash
GEMINI_TEMPERATURE=0.65

# Assistant persona (dev-mentor = Arjun | support-coach = Meera)
ASSISTANT_PERSONA=dev-mentor
ASSISTANT_NAME=

# Sarvam AI — STT + TTS
# Get key at https://dashboard.sarvam.ai/ (free credits on signup)
SARVAM_API_KEY=your-sarvam-api-key

# Sarvam STT — use "unknown" for auto-detect (Hindi, Marathi, Gujarati, English, etc.)
SARVAM_STT_MODEL=saarika:v2.5
SARVAM_STT_LANGUAGE_CODE=unknown
SARVAM_STT_MODE=transcribe

# Sarvam TTS — "auto" mirrors user language; or set hi-IN, mr-IN, gu-IN, en-IN
SARVAM_SPEAKER=rohan
SARVAM_MODEL=bulbul:v3
SARVAM_LANGUAGE_CODE=auto
DEFAULT_LANGUAGE_CODE=en-IN
SARVAM_SAMPLE_RATE=24000
SARVAM_OUTPUT_CODEC=wav
SARVAM_PACE=0.92
SARVAM_TEMPERATURE=0.72

# Tavily Web Search (optional — 1,000 free credits/month at https://tavily.com)
TAVILY_API_KEY=tvly-your-tavily-key
SEARCH_MAX_RESULTS=5

# Session memory (SQLite path relative to project root)
SESSION_DB_PATH=data/sessions.db
SESSION_TTL_HOURS=24
MAX_HISTORY_TURNS=20

# Server
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
CORS_ORIGINS=*
